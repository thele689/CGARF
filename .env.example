# Copy this file to .env and fill only the providers you use.

# OpenAI-compatible providers
OPENAI_API_KEY=
OPENAI_API_BASE=

# vLLM OpenAI-compatible local server. VLLM_API_KEY may stay EMPTY.
VLLM_API_KEY=EMPTY
VLLM_API_BASE=http://localhost:8000/v1

# Generic Qwen-compatible endpoint
QWEN_API_KEY=
QWEN_API_BASE=https://api.siliconflow.cn/v1

# SiliconFlow
SILICONFLOW_API_KEY=
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1

# DashScope / Bailian
DASHSCOPE_API_KEY=
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# Runtime tuning
QWEN_REQUEST_TIMEOUT_SECONDS=30
QWEN_MAX_RETRY_ATTEMPTS=3
QWEN_MIN_REQUEST_INTERVAL_SECONDS=0
QWEN_RATE_LIMIT_BACKOFF_SECONDS=20
QWEN_FORCE_REQUESTS=0
